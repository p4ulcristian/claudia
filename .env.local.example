# Path to the `claude` CLI binary. Defaults to ~/.local/bin/claude if present,
# otherwise `claude` on PATH.
# CLAUDE_BIN=/usr/local/bin/claude

# Model to run. Defaults to the freshest model below.
CLAUDE_MODEL=claude-opus-4-8

# Where claudia stores its watched-folder list and reads session transcripts.
# Defaults to the OS home directory's ~/.claude.
# CLAUDE_HOME=/home/you/.claude
